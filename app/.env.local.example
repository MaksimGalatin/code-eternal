# ── Vercel dashboard: Settings → Environment Variables ──────────────────────
# Paste all three below into Vercel. They are prefixed NEXT_PUBLIC_ so they
# are safe to expose in the browser bundle.

# 1. From privy.io dashboard → App ID
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# 2. Deployed contract on Devnet (already in code — override here if it changes)
NEXT_PUBLIC_PROGRAM_ID=8rzMmrC6UH5gCringWk1NsRXtfWkrfjz91tT5dmEGAep

# 3. Helius RPC — public key only, no secret
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=bb310470-cf7c-42a5-80af-60fe93a6784b
